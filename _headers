# Cloudflare Pages: no cachear el HTML para que todos los dispositivos
# (admin, garzón, cocina, y el visor público /carta) carguen siempre la última versión.
/
  Cache-Control: no-cache, no-store, must-revalidate
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
/carta
  Cache-Control: no-cache, no-store, must-revalidate
/carta/
  Cache-Control: no-cache, no-store, must-revalidate
